TX_RISK_API_KEY=change-me
SIGNSSHIELD_HTTP_MODE=production
SIGNSSHIELD_PUBLIC_RPC_FALLBACK=true
SIGNSSHIELD_CORS_ORIGINS=*
SIGNSSHIELD_TIMEOUT=30
SIGNSSHIELD_HTTP_THREAD_WORKERS=4

# Optional live enrichment providers
TENDERLY_ACCOUNT_SLUG=
TENDERLY_PROJECT_SLUG=
TENDERLY_ACCESS_KEY=
ETHERSCAN_API_KEY=
BLOCKSCOUT_BASE_URL=
SIGNSSHIELD_RPC_URL=
GOPLUS_BASE_URL=https://api.gopluslabs.io

# Optional Kimi Agent SDK loop. Leave off for deterministic analysis.
SIGNSSHIELD_AGENT_LOOP=off
SIGNSSHIELD_AGENT_LOOP_MODEL=kimi-code/kimi-for-coding
SIGNSSHIELD_AGENT_LOOP_TIMEOUT=30
SIGNSSHIELD_AGENT_LOOP_MAX_STEPS=6
SIGNSSHIELD_AGENT_LOOP_FALLBACK=true
KIMI_BASE_URL=https://api.kimi.com/coding/v1
# Optional provider model override. Leave unset for kimi-for-coding.
KIMI_MODEL_NAME=
KIMI_API_KEY=

# Optional xapi.to CLI/API key for local publishing workflows
XAPI_KEY=
