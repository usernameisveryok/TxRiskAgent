digraph SignShieldSkillFlow {
  graph [
    rankdir=TB,
    bgcolor="white",
    pad="0.35",
    nodesep="0.45",
    ranksep="0.55",
    splines=ortho,
    fontname="PingFang SC",
    labelloc="t",
    label="SignShield Skill 分支结构：事实层 -> 规则层 -> 解释层"
  ];

  node [
    shape=box,
    style="rounded,filled",
    color="#475569",
    penwidth=1.2,
    fillcolor="#f8fafc",
    fontname="PingFang SC",
    fontsize=18,
    margin="0.12,0.08"
  ];

  edge [
    color="#64748b",
    penwidth=1.1,
    arrowsize=0.8,
    fontname="PingFang SC",
    fontsize=14
  ];

  input [label="输入交易 JSON\nchainId / from / to / data / value / origin", fillcolor="#ecfeff"];
  normalize [label="输入规范化与校验\nEVM chain、地址、hex、origin、金额", fillcolor="#ecfeff"];

  subgraph cluster_facts {
    label="事实层：Simulation first";
    color="#0891b2";
    penwidth=1.4;
    style="rounded";
    fontname="PingFang SC";
    fontsize=20;

    decode [label="Calldata 解码\nselector / ABI / 标准接口 / 递归 multicall", fillcolor="#e0f2fe"];
    simulate [label="交易模拟\n余额变化 / 授权变化 / NFT 归属 / 内部调用 / logs", fillcolor="#e0f2fe"];
    contract [label="合约透明度\n源码验证 / proxy / implementation / 部署时间 / 标签", fillcolor="#e0f2fe"];
    domain [label="来源与情报\norigin denylist / GoPlus / OFAC / abuse reports", fillcolor="#e0f2fe"];
    bytecode [label="未开源 fallback\nbytecode proxy / delegatecall / clone / selfdestruct", fillcolor="#e0f2fe"];
  }

  classify [label="行为分类器\n从事实中抽取用户真正要签的动作", fillcolor="#fef3c7"];

  subgraph cluster_branches {
    label="规则层：风险分支";
    color="#d97706";
    penwidth=1.4;
    style="rounded";
    fontname="PingFang SC";
    fontsize=20;

    b_native [label="Native 转账\n普通收款人 / burn 地址 / 可疑地址 / 大额流出", fillcolor="#fff7ed"];
    b_erc20_approval [label="ERC20 授权\napprove / Permit2 / 无限或过量授权 / 陌生 spender", fillcolor="#fff7ed"];
    b_nft_approval [label="NFT 授权\nsetApprovalForAll / collection 全集权限", fillcolor="#fff7ed"];
    b_token_transfer [label="Token 转移\ntransfer / transferFrom / simulation 资产流出", fillcolor="#fff7ed"];
    b_multicall [label="聚合执行\nmulticall / execute / arbitrary call 递归展开", fillcolor="#fff7ed"];
    b_unknown [label="未知或未验证合约\n未开源 + 新部署 + 低交互 + 隐藏逻辑风险", fillcolor="#fff7ed"];
    b_revert [label="失败或不确定\nrevert / 模拟不可用 / 数据不足", fillcolor="#fff7ed"];
  }

  evidence [label="证据归并\nassetImpact + riskFactors + limitations", fillcolor="#f1f5f9"];
  scoring [label="评分与等级\nLow / Medium / High / Critical\n技术风险、欺诈风险、合规风险分开计分", fillcolor="#fee2e2"];
  policy [label="策略建议\nReject / reduce allowance / burner wallet / continue with caution", fillcolor="#fee2e2"];
  explain [label="解释层：AI second\n只解释结构化事实，不编造链上结论", fillcolor="#dcfce7"];
  output [label="输出 JSON 风险结构\nverdict / summary / intent / assetImpact / factors / evidence / recommendation", fillcolor="#dcfce7"];

  input -> normalize;
  normalize -> decode;
  normalize -> simulate;
  normalize -> contract;
  normalize -> domain;
  contract -> bytecode [label="未验证或 proxy"];

  decode -> classify;
  simulate -> classify;
  contract -> classify;
  domain -> classify;
  bytecode -> classify;

  classify -> b_native [label="data 为空且 value > 0"];
  classify -> b_erc20_approval [label="approve / permit"];
  classify -> b_nft_approval [label="setApprovalForAll"];
  classify -> b_token_transfer [label="transfer 行为"];
  classify -> b_multicall [label="批量或任意调用"];
  classify -> b_unknown [label="selector 未知或合约不可读"];
  classify -> b_revert [label="模拟失败或信息不足"];

  b_native -> evidence;
  b_erc20_approval -> evidence;
  b_nft_approval -> evidence;
  b_token_transfer -> evidence;
  b_multicall -> evidence;
  b_unknown -> evidence;
  b_revert -> evidence;

  evidence -> scoring;
  scoring -> policy;
  policy -> explain;
  explain -> output;
}
